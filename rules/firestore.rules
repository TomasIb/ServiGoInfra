rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ REGLAS DE PRODUCCIÓN / SEGURIDAD
    // Solo permitimos acceso a usuarios autenticados o a nuestros IDs de Demo.

    // Helper: Identifica si es un usuario de Demo (usado en el modo invitado)
    function isDemoUser() {
      // Si el usuario está autenticado, verificamos su UID
      // Si no lo está, verificamos si es una operación de escritura con un ID de demo admitido
      return (request.auth != null && request.auth.uid in ['guest_client_1', 'provider_1', 'guest_admin_1']) ||
             (request.auth == null && request.resource != null && 
              (request.resource.data.uid in ['guest_client_1', 'provider_1', 'guest_admin_1'] ||
               request.resource.data.clientId in ['guest_client_1', 'provider_1', 'guest_admin_1'] ||
               request.resource.data.providerId in ['guest_client_1', 'provider_1', 'guest_admin_1']));
    }

    // Helper: Admin real o Admin de Demo
    function isAdmin() {
      return (request.auth != null && (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
               request.auth.uid == 'guest_admin_1'
             )) ||
             (request.auth == null && request.path[4] == 'users' && request.path[5] == 'guest_admin_1');
    }

    // Colección: Usuarios
    match /users/{userId} {
      allow read: if true;
      allow create: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow update: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Colección: Servicios
    match /services/{serviceId} {
      // Permitir lectura a todos los autenticados para que puedan ver perfiles y calcular promedios
      allow read: if true;
      
      // Permitir creación por el dueño o admin
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.providerId || isAdmin());
      
      // Permitir actualizaciones:
      // 1. Por el proveedor (dueño) o Admin
      // 2. Por cualquier cliente autenticado que SÓLO esté actualizando el rating y reviewCount
      allow update: if (request.auth != null && (request.auth.uid == resource.data.providerId || isAdmin())) ||
                    (request.auth != null && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));

      allow delete: if isAdmin();
    }

    // Colección: Reservas
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if request.auth != null || isDemoUser();
      allow update: if request.auth != null || isDemoUser() || isAdmin();
      allow delete: if isAdmin();
    }

    // Colección de Configuraciones (Crucial leer para la App)
    match /configurations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Resto de colecciones (Mensajes, Notificaciones, etc)
    match /notifications/{id} { allow read, write: if request.auth != null || isDemoUser() || isAdmin(); }
    match /chats/{id} { allow read, write: if request.auth != null || isDemoUser() || isAdmin(); }
    match /chats/{id}/messages/{msgId} { allow read, write: if request.auth != null || isDemoUser() || isAdmin(); }
    
    match /reviews/{id} { 
      allow read: if true; 
      allow create: if request.auth != null || isDemoUser(); 
    }
    
    match /provider_schedules/{id} { allow read, write: if true; }

    // Colección: Favoritos (Sincronización Cloud)
    match /user_favorites/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // Por defecto bloquear todo lo demás
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

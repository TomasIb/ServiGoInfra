# ── Firebase Client SDK (used by seed scripts) ──────────────
FIREBASE_API_KEY=your-api-key-here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ── Admin User (used by seed-config.mjs --admin) ────────────
ADMIN_EMAIL=admin@servigo.cl
ADMIN_PASSWORD=your-secure-admin-password

# ── Demo Accounts (used by seed-demo.mjs) ────────────────────
DEMO_PASSWORD=your-demo-password

# ── MercadoPago (used by Cloud Functions) ────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxx
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret
MERCADOPAGO_CLIENT_ID=your-client-id
MERCADOPAGO_CLIENT_SECRET=your-client-secret

# ── Google Cloud (auto-set in Cloud Functions, needed locally) ─
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# GCLOUD_PROJECT=your-project-id
